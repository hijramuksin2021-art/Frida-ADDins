# Salin file ini menjadi .env lalu isi nilainya. .env TIDAK ikut ter-commit.
# Semua key opsional di sini — bisa juga diisi lewat panel Pengaturan di add-in (tanpa restart).
# Nilai tersimpan di provider.local.json (gitignored).

# Provider aktif saat start: anthropic | openai | gemini | custom
FRIDA_PROVIDER=custom

# --- Custom / OpenAI-compatible (9Router / Aerolink / proxy lain) ---
AERO_API_KEY=
AERO_BASE_URL=https://capi.aerolink.lat/
FRIDA_MODEL=

# --- Provider resmi (endpoint dikunci di server; cukup isi API key) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Model default per provider (opsional — bisa dipilih di UI):
FRIDA_ANTHROPIC_MODEL=claude-opus-4-8
FRIDA_OPENAI_MODEL=gpt-5
FRIDA_GEMINI_MODEL=gemini-2.5-pro

# Batas token & port server lokal.
FRIDA_MAX_TOKENS=8000
FRIDA_PORT=3001

# URL publik add-in (dipakai untuk manifest.xml: SourceLocation, IconUrl, AppDomains, dll).
# Development lokal: kosongkan -> otomatis fallback ke https://localhost:3001.
# Produksi (mis. Railway): isi URL publik hasil deploy, TANPA trailing slash. Contoh:
#   PUBLIC_URL=https://frida-addins-production.up.railway.app
# Catatan: di Railway, RAILWAY_PUBLIC_DOMAIN juga dibaca otomatis bila PUBLIC_URL kosong.
# Setelah mengubah nilai ini, jalankan `npm run manifest` (atau `npm start`) untuk regen manifest.xml.
PUBLIC_URL=

# --- Embeddings (Research Copilot / RAG) — "API key all provider" ---
# Provider apa pun yang OpenAI-compatible: POST {EMBED_BASE_URL}/embeddings
# Pilih: openai (remote, pakai baseUrl+key) | local (Xenova, ditambahkan di R1).
EMBED_PROVIDER=openai
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-large
EMBED_DIM=3072
