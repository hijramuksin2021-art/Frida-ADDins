# Salin file ini menjadi .env lalu isi nilainya. .env TIDAK ikut ter-commit.
# API key provider (rahasia — wajib).
AERO_API_KEY=
# Endpoint provider (boleh default).
AERO_BASE_URL=https://capi.aerolink.lat/
# Model & batas token.
FRIDA_MODEL=claude-opus-4-8
FRIDA_MAX_TOKENS=8000
# Port server lokal.
FRIDA_PORT=3001

# --- Embeddings (Research Copilot / RAG) — "API key all provider" ---
# Provider apa pun yang OpenAI-compatible: POST {EMBED_BASE_URL}/embeddings
# Pilih: openai (remote, pakai baseUrl+key) | local (Xenova, ditambahkan di R1).
EMBED_PROVIDER=openai
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-large
EMBED_DIM=3072
